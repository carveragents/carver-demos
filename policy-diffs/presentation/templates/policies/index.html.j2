{% extends "_base.html.j2" %}
{% block title %}{{ config.brand.client }} Policies — index{% endblock %}
{% block content %}

<nav class="breadcrumb">
  <a href="{{ assets_prefix }}timeline/index.html">Timeline</a>
  <span class="sep">›</span>
  <span class="current">Policies</span>
</nav>

<p class="eyebrow">{{ config.brand.client }} policy library</p>
<h1>Policies</h1>

<p class="lede">
{%- if policies %}<strong>{{ policies|length }} polic{% if policies|length != 1 %}ies{% else %}y{% endif %}</strong> evaluated against {{ config.artifact.long }} — <strong>{{ total_changes }} proposed revision{% if total_changes != 1 %}s{% endif %}</strong> across <strong>{{ release_count }} release{% if release_count != 1 %}s{% endif %}</strong>.{% endif -%}
</p>

<div class="policies-grid">
{% for p in policies %}
<a class="policy-card" href="{{ p.slug }}.html">
  <h3>{{ p.name }}</h3>
  <p class="desc">{{ p.description }}</p>
  <div class="count">
    {% if p.change_count %}
      {{ p.change_count }} proposed revision{% if p.change_count != 1 %}s{% endif %}
      {% if p.breaking_count %} · <strong style="color: var(--mat-breaking-bg);">{{ p.breaking_count }} breaking</strong>{% endif %}
      · {{ p.release_count }} release{% if p.release_count != 1 %}s{% endif %} touched
    {% else %}
      No proposed revisions yet
    {% endif %}
  </div>
  {% if p.change_count %}
  <div class="severity-bar" aria-hidden="true">
    {% if p.materiality_counts.breaking %}<span class="seg-breaking" style="width: {{ p.pct.breaking }}%"></span>{% endif %}
    {% if p.materiality_counts.substantive %}<span class="seg-substantive" style="width: {{ p.pct.substantive }}%"></span>{% endif %}
    {% if p.materiality_counts.clarifying %}<span class="seg-clarifying" style="width: {{ p.pct.clarifying }}%"></span>{% endif %}
    {% if p.materiality_counts.cosmetic %}<span class="seg-cosmetic" style="width: {{ p.pct.cosmetic }}%"></span>{% endif %}
  </div>
  {% endif %}
  <svg class="chev" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
</a>
{% endfor %}
</div>

{% endblock %}
