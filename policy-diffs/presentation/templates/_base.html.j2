<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{% block title %}{{ config.brand.client }} {{ config.brand.product }}{% endblock %}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="{{ assets_prefix }}assets/style.css">
</head>
<body class="{% block body_class %}{% endblock %}">
  <svg class="icon-sprite" aria-hidden="true" focusable="false">
    <defs>
      <symbol id="icon-doc" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
        <polyline points="14 2 14 8 20 8"/>
        <line x1="16" y1="13" x2="8" y2="13"/>
        <line x1="16" y1="17" x2="8" y2="17"/>
        <polyline points="10 9 9 9 8 9"/>
      </symbol>
      <symbol id="icon-book" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/>
        <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
      </symbol>
      <symbol id="icon-external" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
        <polyline points="15 3 21 3 21 9"/>
        <line x1="10" y1="14" x2="21" y2="3"/>
      </symbol>
    </defs>
  </svg>
  <header class="site-header">
    <div class="container">
      <a href="{{ assets_prefix }}index.html" class="brand">{{ config.brand.client }} <span class="sep">·</span> {{ config.brand.product }}</a>
      <nav class="site-nav">
        <a href="{{ assets_prefix }}index.html">Overview</a>
        <a href="{{ assets_prefix }}timeline/index.html">Timeline</a>
        <a href="{{ assets_prefix }}policies/index.html">Policies</a>
      </nav>
      <span class="site-tagline">{{ config.brand.tagline }}</span>
    </div>
  </header>
  <main class="container">
    {% block content %}{% endblock %}
  </main>
  <footer class="site-footer">
    <div class="container">
      {{ config.brand.footer_note }}
    </div>
  </footer>
  {% block scripts %}{% endblock %}
</body>
</html>
