# Copy to .env and fill in real values. .env is gitignored.

# Required: OpenAI API key for the classify / map / propose pipeline stages.
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Optional: override the model used at any individual pipeline stage.
# (Defaults are read from config/models.yaml; these env vars are reserved for
# future use — not yet wired through the config loader.)
# POLICY_DIFFS_MODEL_CLASSIFY=gpt-5.4-mini
# POLICY_DIFFS_MODEL_MAP=gpt-5.4-mini
# POLICY_DIFFS_MODEL_PROPOSE=gpt-5.4-mini

# Optional: TTS voiceover config for scripts/render_voiceover.py.
# Defaults shown below; override here to swap voice or model.
# TTS_MODEL=gpt-4o-mini-tts
# TTS_VOICE=cedar
